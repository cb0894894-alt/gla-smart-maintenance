# Google Apps Script Web App endpoint used by the dashboard.
# The dashboard appends ?accion=<modulo> when loading Google Sheets data.
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Google OAuth (no secrets should be committed outside local/hosting env vars).
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Random 32+ character secret used to sign the application session cookie.
AUTH_SECRET=replace-with-a-long-random-local-secret
